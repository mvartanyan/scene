# Copy to .env.staging on the Linux staging host and adjust before starting.

SCENE_APP_IMAGE=scene-app:staging
SCENE_RUNNER_IMAGE=scene-playwright-runner:1.47.0-jammy

# Bind to 127.0.0.1 when a reverse proxy terminates TLS/auth on the same host.
# Use 0.0.0.0 for direct host.docker.internal callback smoke tests without a proxy.
SCENE_BIND_IP=127.0.0.1
SCENE_HTTP_PORT=8010

# Stable URL used by runner containers for callbacks and by reviewers for artifacts.
SCENE_HOST_URL=https://scene-staging.example.com
SCENE_BASE_URL=https://scene-staging.example.com
SCENE_API_TOKEN=replace-with-staging-agent-token
SCENE_ARTIFACT_BASE_URL=/artifacts
SCENE_ARTIFACT_STORAGE=filesystem

# Local Docker staging keeps JSON state. Production/k3s uses dynamodb with the
# AWS region/table variables below.
SCENE_STATE_BACKEND=json
# AWS_REGION=eu-central-1
# SCENE_DYNAMODB_TABLE=scene-staging

# Keep these absolute host paths outside the git checkout. The app container and
# sibling runner containers must see the same artifact path through the Docker host.
SCENE_STATE_DIR=/var/lib/scene/staging/state
SCENE_STATE_PATH=/var/lib/scene/staging/state/scene.dynamodb.json
SCENE_ARTIFACT_ROOT=/var/lib/scene/staging/artifacts

# Local Linux Docker staging runs containers directly. k3s should use
# SCENE_RUNNER_BACKEND=k3s plus a cluster service URL and shared PVC.
SCENE_RUNNER_BACKEND=docker
SCENE_RUNNER_IMAGE_AUTOBUILD=false
SCENE_RUNNER_SHM_SIZE=1g
SCENE_RUNNER_EXTRA_HOST_GATEWAY=true

SCENE_MAX_CONCURRENT_EXECUTIONS=2
SCENE_RUN_TIMEOUT_SECONDS=900
SCENE_CAPTURE_DELAY_MS=7000
SCENE_DIFF_PIXEL_TOLERANCE=0

# k3s example values:
# SCENE_RUNNER_BACKEND=k3s
# SCENE_K3S_NAMESPACE=scene
# SCENE_K3S_SERVICE_URL=http://scene.scene.svc.cluster.local:8000
# SCENE_K3S_RUNNER_SERVICE_ACCOUNT=scene-runner
# SCENE_K3S_IMAGE_PULL_POLICY=IfNotPresent
# SCENE_ARTIFACT_STORAGE=pvc
# SCENE_ARTIFACT_PVC_CLAIM=scene-artifacts
# SCENE_RUNNER_CPU_REQUEST=500m
# SCENE_RUNNER_CPU_LIMIT=2
# SCENE_RUNNER_MEMORY_REQUEST=512Mi
# SCENE_RUNNER_MEMORY_LIMIT=2Gi
